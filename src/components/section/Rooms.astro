---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { content } from '../../config/content';

const { title, items } = content.rooms;
---
<section class="section rooms" id="rooms">
  <div class="inner rooms-inner">
    <header class="section-title">
      <h2 class="title">{ title }</h2>
    </header>
    <ul class="pills">
      {items.map((item) => (
        <li class="pill-item">
          <a href={`#room-${item.id}`} class="pill-link">{item.id}</a>
        </li>
      ))}
    </ul>
    <ul class="list">
      {items.map((item) => (
        <li class="item" id={`room-${item.id}`}>
          <div class="media" data-slider={`room-${item.id}`}>
            <div class="slides">
              {item.images.map((src, i) => (
                <Image class:list={['media-img', { 'is-active': i === 0 }]} src={src} alt={item.name} data-slide={i} />
              ))}
            </div>
            {item.images.length > 1 && (
              <>
                <button class="media-nav prev" type="button" data-slider-prev aria-label="前の写真"><Icon name="mdi:chevron-left" /></button>
                <button class="media-nav next" type="button" data-slider-next aria-label="次の写真"><Icon name="mdi:chevron-right" /></button>
                <div class="media-dots">
                  {item.images.map((_, i) => (
                    <button class:list={['media-dot', { 'is-active': i === 0 }]} type="button" data-slider-dot={i} aria-label={`${i + 1}枚目`}></button>
                  ))}
                </div>
              </>
            )}
          </div>
          <div class="body">
            <h3 class="name">{item.name}</h3>
            <div class="reserve-links">
              <a class="reserve-link airbnb" href={item.airbnb} target="_blank" rel="noopener noreferrer">
                <Icon name="simple-icons:airbnb" /> airbnb
              </a>
              <a class="reserve-link booking" href={item.booking} target="_blank" rel="noopener noreferrer">
                <Icon name="simple-icons:bookingdotcom" /> Booking.com
              </a>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .rooms-inner {
    max-width: 720px;
  }

  .title {
    text-align: center;
  }

  // ピルタグ
  .pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
  }

  .pill-link {
    padding: 6px 20px;
    border: 1px solid rgba($color-base, 0.3);
    font-size: $fs-sm;
    letter-spacing: 0.1em;
    transition: background 0.3s ease, color 0.3s ease;

    &:hover {
      background: $color-base;
      color: #fff;
    }
  }

  // カードリスト
  .list {
    display: flex;
    flex-direction: column;
    gap: 64px;
    margin-top: 48px;
  }

  .item {
    scroll-margin-top: 80px;
  }

  // メディア(画像エリア)
  .media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
  }

  .slides,
  .media-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .media-img {
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.8s ease;

    &.is-active {
      opacity: 1;
    }
  }

  .media-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.8);
    border: none;
    border-radius: 50%;
    font-size: 20px;

    &.prev { left: 12px; }
    &.next { right: 12px; }
  }

  .media-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: flex;
    gap: 8px;
  }

  .media-dot {
    width: 8px;
    height: 8px;
    padding: 0;
    background: rgba(255, 255, 255, 0.5);
    border: none;
    border-radius: 50%;

    &.is-active {
      background: #fff;
    }
  }

  // 号室情報
  .body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 20px;
  }

  .name {
    font-size: $fs-lg;
    letter-spacing: 0.15em;
  }

  // 予約ボタン
  .reserve-links {
    display: flex;
    gap: 8px;
  }

  .reserve-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    color: #fff;
    font-size: $fs-sm;
    @include hover-opacity;

    &.airbnb {
      background: #ff5a5f;
    }
    &.booking {
      background: #003580;
    }
  }

  @include sp {
    .body {
      justify-content: center;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-slider]').forEach((slider) => {
    const slides = slider.querySelectorAll<HTMLElement>('[data-slide]');
    const dots = slider.querySelectorAll<HTMLElement>('[data-slider-dot]');
    const prev = slider.querySelector<HTMLElement>('[data-slider-prev]');
    const next = slider.querySelector<HTMLElement>('[data-slider-next]');
    if (slides.length < 2) return;

    let current = 0;
    const goTo = (i: number) => {
      const idx = (i + slides.length) % slides.length;
      slides[current]?.classList.remove('is-active');
      dots[current]?.classList.remove('is-active');
      current = idx;
      slides[current]?.classList.add('is-active');
      dots[current]?.classList.add('is-active');
    };

    prev?.addEventListener('click', () => goTo(current - 1));
    next?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  });
</script>