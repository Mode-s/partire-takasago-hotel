---
import { siteConfig } from '../../config/site';

const { shop } = siteConfig;
---
<section class="section info" id="info">
  <div class="inner info-inner">
    <header class="section-title">
      <h2 class="title">Info</h2>
    </header>
    <dl class="info-list">
      {shop.address && (
        <>
          <dt class="info-label">住所</dt>
          <dd class="info-data">{shop.address}</dd>
        </>
      )}
      {shop.tel.display && (
        <>
          <dt class="info-label">電話</dt>
          <dd class="info-data">
            <a href={`tel:${shop.tel.link}`}>{shop.tel.display}</a>
          </dd>
        </>
      )}
      {shop.checkin   && (
        <>
          <dt class="info-label">チェックイン</dt>
          <dd class="info-data">{shop.checkin}</dd>
        </>
      )}
      {shop.checkout  && (
        <>
          <dt class="info-label">チェックアウト</dt>
          <dd class="info-data">{shop.checkout}</dd>
        </>
      )}
      {shop.parking && (
        <>
          <dt class="info-label">駐車場</dt>
          <dd class="info-data">{shop.parking}</dd>
        </>
      )}
    </dl>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;
  
  .info-inner {
    max-width: 560px;
  }

  .title {
    text-align: center;
  }

  .info-list {
    display: grid;
    grid-template-columns: 120px 1fr;
    margin-top: 40px;
  }

  .info-label,
  .info-data {
    padding: 16px 0;
    border-bottom: 1px solid rgba($color-base, 0.15);
  }

  .info-label {
    font-size: $fs-sm;
    font-weight: 500;
    color: rgba($color-base, 0.7);
    letter-spacing: 0.08em;
  }

  .info-data {
    font-weight: 500;
    line-height: 1.8;

    a {
      display: inline-block;
      transition: opacity 0.3s ease;
      &:hover {
        opacity: 0.7;
      }
    }
  }

  @include sp {

    .info-list {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .info-label {
      padding-bottom: 0;
      border-bottom: none;
    }

    .info-data {
      padding-top: 0;
      padding-bottom: 20px;
    }
  }
</style>