---
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../../config/site';

const { site, room, shop } = siteConfig;

const Links = [
  { label: "airbnb",         href: site.airbnb,         icon: "simple-icons:airbnb" },
  { label: "Booking.com",         href: site.booking,         icon: "simple-icons:bookingdotcom" },
].filter(( item ) => item.href );
---
<section class="section contact" id="contact">
  <div class="inner contact-inner">
    <header class="section-title">
      <h2 class="title">Contact</h2>
    </header>
    <div class="actions">
      { Links.length > 0 && (
        <ul class="sns-list">
          { Links.map(( item ) => (
            <li class="sns-item">
              <a class:list={['sns-link', item.label.toLowerCase().includes('airbnb') ? 'airbnb' : 'booking']} href={ item.href } target="_blank" rel="noopener noreferrer">
                <Icon class="sns-icon" name={item.icon} />
                <p class="label">{item.label}</p>
              </a>
            </li>
          ))}
        </ul>
      )}
      { shop.tel.display && (
        <a class="tel" href={`tel:${ shop.tel.link }`}>
          <Icon class="contact-tel-icon" name="mdi:phone" />
          <p class="label">{ shop.tel.display }</p>
        </a>
      )}
    </div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  // ―――――――――――――――――――――――――――――――――――
  .contact-inner {
  max-width: 560px;
}
.title {
  text-align: center;
}
.actions {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 40px;
}
.tel,
.sns-link {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px 24px;
  background: #fff;
  border: 1px solid rgba($color-base, 0.12);
  transition: opacity 0.3s ease, box-shadow 0.3s ease;
  &:hover {
    opacity: 0.85;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }
}
.contact-tel-icon,
.sns-icon {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
}
.label {
  font-weight: 500;
  letter-spacing: 0.05em;
}
.tel {
  font-size: $fs-lg;
}
.sns-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

@include sp {
  .actions {
    margin-top: 32px;
    gap: 12px;
  }
  .tel,
  .sns-link {
    padding: 16px 20px;
  }
  .tel {
    font-size: $fs-base;
  }
}
</style>