---
import { siteConfig } from '../../config/site';

const { shop, name } = siteConfig;
---
<section class="section access" id="access">
  <div class="inner access-inner">
    <header class="section-title">
      <h2 class="title">Access</h2>
    </header>
    {shop.address && <p class="address">{shop.address}</p>}
    {shop.map && (
      <div class="access-map">
        <iframe class="map" src={shop.map} title={`${name}の地図`} loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen ></iframe>
      </div>
    )}
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;
  
  .access-inner {
    max-width: 800px;
  }

  .title {
    text-align: center;
  }

  .address {
    margin-top: 40px;
    text-align: center;
    font-weight: 500;
    line-height: 1.8;
  }

  .access-text {
    margin-top: 16px;
    text-align: center;
    font-size: $fs-sm;
    color: rgba($color-base, 0.7);
    line-height: 1.8;
  }

  .access-map {
    margin-top: 32px;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.3s ease, transform 0.3s ease;

    &:hover {
      box-shadow: 0 10px 32px rgba(0, 0, 0, 0.16);
      transform: translateY(-4px);
    }
  }

  .map {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  @include sp {
    .address {
      margin-top: 32px;
      font-size: $fs-sm;
    }

    .access-map {
      margin-top: 24px;
      border-radius: 4px;
    }

    .map {
      aspect-ratio: 4 / 3;
    }
  }
</style>