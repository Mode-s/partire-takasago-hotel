---
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../../config/site';

const { site } = siteConfig;
---

<div class="reserve">
  <button class="reserve-toggle" type="button" aria-haspopup="dialog" aria-controls="reserve-modal">予約する</button>
</div>

<div class="reserve-modal" id="reserve-modal" aria-hidden="true">
  <div class="reserve-overlay" data-close></div>
  <div class="reserve-dialog" role="dialog" aria-modal="true" aria-label="予約サイトを選択">
    <button class="reserve-close" type="button" aria-label="閉じる" data-close>×</button>
    <p class="reserve-title">予約サイトを選択</p>
    <ul class="reserve-list">
      <li>
        <a class="reserve-link" href={site.airbnb} target="_blank" rel="noopener noreferrer">
          <Icon class="reserve-icon" name="simple-icons:airbnb" />
          <span>airbnbで予約する</span>
        </a>
      </li>
      <li>
        <a class="reserve-link" href={site.booking} target="_blank" rel="noopener noreferrer">
          <Icon class="reserve-icon" name="simple-icons:bookingdotcom" />
          <span>Booking.comで予約する</span>
        </a>
      </li>
    </ul>
  </div>
</div>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  /* 右固定ボタン（変更なし） */
  .reserve {
    position: fixed;
    top: 50%;
    right: 0;
    z-index: 90;
    display: flex;
    transform: translateY(-50%);
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  body.is-scrolling .reserve {
    transform: translateY(-50%) translateX(100%);
    opacity: 0;
    pointer-events: none;
  }

  .reserve-toggle {
    writing-mode: vertical-rl;
    padding: 16px 8px;
    background: $color-base;
    color: #fff;
    border-radius: 8px 0 0 8px;
    letter-spacing: 0.15em;
    white-space: nowrap;
  }

  /* モーダル */
  .reserve-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease;
  }

  .reserve-modal.is-open {
    opacity: 1;
    visibility: visible;
  }

  .reserve-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .reserve-dialog {
    position: relative;
    width: 90%;
    max-width: 400px;
    padding: 40px 24px 32px;
    background: #fff;
    border-radius: 12px;
  }

  .reserve-close {
    position: absolute;
    top: 8px;
    right: 12px;
    font-size: 1.5rem;
    line-height: 1;
    color: $color-base;
  }

  .reserve-title {
    margin-bottom: 24px;
    text-align: center;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .reserve-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .reserve-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border: 1px solid rgba($color-base, 0.15);
    font-weight: 500;
    transition: background 0.3s ease;

    &:hover {
      background: rgba($color-base, 0.05);
    }
  }

  .reserve-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
  }
</style>

<script>
  const modal = document.querySelector('.reserve-modal');
  const toggle = document.querySelector('.reserve-toggle');

  const open = () => {
    modal?.classList.add('is-open');
    modal?.setAttribute('aria-hidden', 'false');
    document.documentElement.classList.add('is-locked');
  };
  const close = () => {
    modal?.classList.remove('is-open');
    modal?.setAttribute('aria-hidden', 'true');
    document.documentElement.classList.remove('is-locked');
  };

  toggle?.addEventListener('click', open);
  modal?.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
  document.addEventListener('keydown', (e) => e.key === 'Escape' && close());
</script>